{
  "name": "@pen/vue",
  "version": "0.0.0",
  "description": "Vue rendering primitives for Pen",
  "license": "SEE LICENSE IN LICENSE.md",
  "homepage": "https://github.com/niceperson/pen#readme",
  "bugs": {
    "url": "https://github.com/niceperson/pen/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/niceperson/pen.git",
    "directory": "packages/rendering/vue"
  },
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./plugin": {
      "import": {
        "types": "./dist/plugin.d.ts",
        "default": "./dist/plugin.mjs"
      },
      "require": {
        "types": "./dist/plugin.d.cts",
        "default": "./dist/plugin.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "pnpm --filter @pen/preset-default build && vitest run",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@pen/core": "workspace:*",
    "@pen/dom": "workspace:*",
    "@pen/types": "workspace:*"
  },
  "peerDependencies": {
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@pen/preset-default": "workspace:*",
    "@pen/test": "workspace:*",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^28.1.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.7",
    "vue": "^3.5.30"
  }
}
