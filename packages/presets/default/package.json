{
  "name": "@pen/preset-default",
  "version": "0.0.0",
  "description": "Default batteries-included editor preset for Pen",
  "license": "SEE LICENSE IN LICENSE.md",
  "homepage": "https://github.com/niceperson/pen#readme",
  "bugs": {
    "url": "https://github.com/niceperson/pen/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/niceperson/pen.git",
    "directory": "packages/presets/default"
  },
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@pen/delta-stream": "workspace:*",
    "@pen/document-ops": "workspace:*",
    "@pen/shortcuts": "workspace:*",
    "@pen/types": "workspace:*",
    "@pen/undo": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.7"
  }
}
